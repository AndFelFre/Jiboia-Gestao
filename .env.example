# Supabase (Configuração Obrigatória)
# Obtenha estas chaves em: Dashboard do Supabase -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Role de serviço (Nunca use no front-end!): Necessário para ações administrativas de sistema.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Conexão Direta (Opcional, útil para migrations via CLI)
# DATABASE_URL=postgres://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-ID].supabase.co:5432/postgres

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI (Assistente e Sucessão)
OPENAI_API_KEY=your_openai_api_key

# Resend (E-mail Service)
# Pegue sua API Key em: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key
# O e-mail deve estar verificado em: https://resend.com/domains (ou use o onboard da resend para testes)
RESEND_FROM_EMAIL=onboarding@resend.dev

# Push Notifications (PWA)
# Gere suas chaves VAPID rodando: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# Audit and Debug (Opcional)
NEXT_PUBLIC_DEBUG_MODE=false
ENABLE_AUDIT_LOGS=true
